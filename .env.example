# ─────────────────────────────────────────────────────────
#  Kenya News Bot v3 — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── Telegram (required — always active) ───────────────────
# 1. Message @BotFather → /newbot → copy token below
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWXyz
# 2. Message your bot once, then:
#    curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
#    Copy the chat "id" number:
TELEGRAM_CHAT_ID=your_numeric_chat_id
# Your bot's @username (without the @) — used by /invite to build
# a real, tappable share link (e.g. GlobalPulseBot → t.me/GlobalPulseBot)
TELEGRAM_BOT_USERNAME=

# ── WhatsApp (optional — activates automatically when filled) ──
# Leave blank to run Telegram-only.
# Fill in once your Facebook account is aged (~30 days).
# See README § WhatsApp Setup for step-by-step instructions.
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_RECIPIENT_PHONE=
WA_VERIFY_TOKEN=

# ── Persistent Storage (optional but strongly recommended) ──
# Without this, dedup history and feed health reset every
# redeploy — you may get repeat alerts and dead feeds keep
# retrying every cycle instead of auto-pausing.
# 1. Create a free DB at https://upstash.com (no credit card)
# 2. Copy the REST URL + REST Token from your database page:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Server ────────────────────────────────────────────────
PORT=3000

# ── Behaviour ─────────────────────────────────────────────
# Set to true to fire a digest immediately on startup
RUN_ON_START=false
